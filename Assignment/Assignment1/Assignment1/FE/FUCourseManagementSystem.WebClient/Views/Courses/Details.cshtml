@model FUCourseManagementSystem.WebClient.Models.CourseViewModel
@{
    ViewData["Title"] = "Course Details";
}

<h2>Course Details</h2>
<div class="card col-md-6">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-4">Course Code</dt><dd class="col-sm-8">@Model.CourseCode</dd>
            <dt class="col-sm-4">Course Name</dt><dd class="col-sm-8">@Model.CourseName</dd>
            <dt class="col-sm-4">Credits</dt><dd class="col-sm-8">@Model.Credits</dd>
            <dt class="col-sm-4">Department</dt><dd class="col-sm-8">@Model.DepartmentName</dd>
            <dt class="col-sm-4">Description</dt><dd class="col-sm-8">@Model.Description</dd>
            <dt class="col-sm-4">Status</dt><dd class="col-sm-8"><span class="badge @(Model.IsActive ? "bg-success" : "bg-secondary")">@(Model.IsActive ? "Active" : "Inactive")</span></dd>
        </dl>
    </div>
</div>
<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    @if (User.IsInRole("Admin") || User.IsInRole("AcademicStaff"))
    {
        <a asp-action="Edit" asp-route-id="@Model.CourseID" class="btn btn-warning ms-2">Edit</a>
    }
</div>

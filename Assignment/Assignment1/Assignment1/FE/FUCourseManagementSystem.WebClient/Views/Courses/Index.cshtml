@model IEnumerable<FUCourseManagementSystem.WebClient.Models.CourseViewModel>
@{
    ViewData["Title"] = "Courses";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Course Management</h2>
    @if (User.IsInRole("Admin") || User.IsInRole("AcademicStaff"))
    {
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createModal">+ New Course</button>
    }
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-4">
        <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Search by code or name..." />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-primary">Search</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
    </div>
</form>

<table class="table table-hover table-bordered">
    <thead class="table-primary">
        <tr>
            <th>#</th>
            <th>Code</th>
            <th>Name</th>
            <th>Credits</th>
            <th>Department</th>
            <th>Active</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @{ int i = 1; }
        @foreach (var course in Model)
        {
            <tr>
                <td>@i++</td>
                <td>@course.CourseCode</td>
                <td>@course.CourseName</td>
                <td>@course.Credits</td>
                <td>@course.DepartmentName</td>
                <td><span class="badge @(course.IsActive ? "bg-success" : "bg-secondary")">@(course.IsActive ? "Active" : "Inactive")</span></td>
                <td>
                    <a asp-action="Details" asp-route-id="@course.CourseID" class="btn btn-sm btn-info">Detail</a>
                    @if (User.IsInRole("Admin") || User.IsInRole("AcademicStaff"))
                    {
                        <a asp-action="Edit" asp-route-id="@course.CourseID" class="btn btn-sm btn-warning">Edit</a>
                        <button class="btn btn-sm btn-danger"
                                onclick="confirmDelete(@course.CourseID, '@course.CourseName')">Delete</button>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@if (User.IsInRole("Admin") || User.IsInRole("AcademicStaff"))
{
    <!-- Create Modal -->
    <div class="modal fade" id="createModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <form asp-action="Create" method="post">
                    <div class="modal-header">
                        <h5 class="modal-title">New Course</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Course Code *</label>
                            <input name="CourseCode" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Course Name *</label>
                            <input name="CourseName" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Credits *</label>
                            <input name="Credits" type="number" min="1" max="20" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Department *</label>
                            <select name="DepartmentID" class="form-select" asp-items="ViewBag.Departments">
                                <option value="">-- Select --</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Description</label>
                            <textarea name="Description" class="form-control" rows="2"></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Create</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Delete form (hidden) -->
    <form id="deleteForm" method="post">
        @Html.AntiForgeryToken()
    </form>
}

@section Scripts {
<script>
function confirmDelete(id, name) {
    if (!confirm('Delete course "' + name + '"? This cannot be undone.')) return;
    var form = document.getElementById('deleteForm');
    form.action = '/Courses/Delete/' + id;
    form.submit();
}
</script>
}

@model FUCourseManagementSystem.WebClient.Models.ClassSectionViewModel
@{
    ViewData["Title"] = "Class Section Details";
}

<h2>Class Section Details</h2>
<div class="card col-md-7">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-4">Class Code</dt><dd class="col-sm-8">@Model.ClassCode</dd>
            <dt class="col-sm-4">Course</dt><dd class="col-sm-8">@Model.CourseName</dd>
            <dt class="col-sm-4">Lecturer</dt><dd class="col-sm-8">@Model.LecturerName</dd>
            <dt class="col-sm-4">Semester</dt><dd class="col-sm-8">@Model.Semester</dd>
            <dt class="col-sm-4">Room</dt><dd class="col-sm-8">@Model.Room</dd>
            <dt class="col-sm-4">Slot</dt><dd class="col-sm-8">@Model.Slot</dd>
            <dt class="col-sm-4">Start Date</dt><dd class="col-sm-8">@Model.StartDate.ToString("dd/MM/yyyy")</dd>
            <dt class="col-sm-4">End Date</dt><dd class="col-sm-8">@Model.EndDate.ToString("dd/MM/yyyy")</dd>
            <dt class="col-sm-4">Max Students</dt><dd class="col-sm-8">@Model.MaxStudents</dd>
            <dt class="col-sm-4">Status</dt><dd class="col-sm-8"><span class="badge @(Model.IsActive ? "bg-success" : "bg-secondary")">@(Model.IsActive ? "Active" : "Inactive")</span></dd>
        </dl>
    </div>
</div>
<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    @if (User.IsInRole("Admin") || User.IsInRole("AcademicStaff"))
    {
        <a asp-action="Edit" asp-route-id="@Model.ClassID" class="btn btn-warning ms-2">Edit</a>
    }
</div>

@model IEnumerable<FUCourseManagementSystem.WebClient.Models.ClassSectionViewModel>
@{
    ViewData["Title"] = "Class Sections";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Class Sections</h2>
    @if (User.IsInRole("Admin") || User.IsInRole("AcademicStaff"))
    {
        <a asp-action="Create" class="btn btn-primary">+ New Section</a>
    }
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-4">
        <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Search class code or course..." />
    </div>
    <div class="col-md-3">
        <input type="text" name="semester" value="@ViewBag.Semester" class="form-control" placeholder="Semester (e.g. SU26)" />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-primary">Search</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
    </div>
</form>

<table class="table table-hover table-bordered">
    <thead class="table-primary">
        <tr>
            <th>#</th>
            <th>Class Code</th>
            <th>Course</th>
            <th>Lecturer</th>
            <th>Semester</th>
            <th>Room / Slot</th>
            <th>Max</th>
            <th>Active</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @{ int i = 1; }
        @foreach (var s in Model)
        {
            <tr>
                <td>@i++</td>
                <td>@s.ClassCode</td>
                <td>@s.CourseName</td>
                <td>@s.LecturerName</td>
                <td>@s.Semester</td>
                <td>@s.Room / @s.Slot</td>
                <td>@s.MaxStudents</td>
                <td><span class="badge @(s.IsActive ? "bg-success" : "bg-secondary")">@(s.IsActive ? "Active" : "Inactive")</span></td>
                <td>
                    <a asp-action="Details" asp-route-id="@s.ClassID" class="btn btn-sm btn-info">Detail</a>
                    @if (User.IsInRole("Admin") || User.IsInRole("AcademicStaff"))
                    {
                        <a asp-action="Edit" asp-route-id="@s.ClassID" class="btn btn-sm btn-warning">Edit</a>
                        <button class="btn btn-sm btn-danger" onclick="confirmDelete(@s.ClassID, '@s.ClassCode')">Delete</button>
                    }
                    @if (User.IsInRole("Student"))
                    {
                        <form method="post" asp-controller="Enrollments" asp-action="Enroll" style="display:inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="classId" value="@s.ClassID" />
                            <button type="submit" class="btn btn-sm btn-success">Enroll</button>
                        </form>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

<form id="deleteForm" method="post">@Html.AntiForgeryToken()</form>

@section Scripts {
<script>
function confirmDelete(id, code) {
    if (!confirm('Delete class section "' + code + '"?')) return;
    var form = document.getElementById('deleteForm');
    form.action = '/ClassSections/Delete/' + id;
    form.submit();
}
</script>
}

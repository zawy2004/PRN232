@using FUNewsManagement.Web.Models.Dtos
@model List<TagDto>
@{
    ViewData["Title"] = "Tags";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Tags</h1>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createModal">+ New Tag</button>
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Note</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var tag in Model)
        {
            <tr>
                <td>@tag.TagName</td>
                <td>@tag.Note</td>
                <td class="text-end">
                    <button class="btn btn-sm btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#editModal-@tag.TagId">Edit</button>
                    <button class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#deleteModal-@tag.TagId">Delete</button>
                </td>
            </tr>

            <div class="modal fade" id="editModal-@tag.TagId" tabindex="-1">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <form asp-controller="Tag" asp-action="Edit" asp-route-id="@tag.TagId" method="post">
                            <div class="modal-header">
                                <h5 class="modal-title">Edit Tag</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body">
                                <div class="mb-3">
                                    <label class="form-label">Name</label>
                                    <input name="TagName" value="@tag.TagName" class="form-control" required />
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Note</label>
                                    <input name="Note" value="@tag.Note" class="form-control" />
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                <button type="submit" class="btn btn-primary">Save</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <div class="modal fade" id="deleteModal-@tag.TagId" tabindex="-1">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <form asp-controller="Tag" asp-action="Delete" asp-route-id="@tag.TagId" method="post">
                            <div class="modal-header">
                                <h5 class="modal-title">Delete Tag</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body">
                                Delete tag <strong>@tag.TagName</strong>? This cannot be undone.
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                <button type="submit" class="btn btn-danger">Delete</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        }
    </tbody>
</table>

<div class="modal fade" id="createModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-controller="Tag" asp-action="Create" method="post">
                <div class="modal-header">
                    <h5 class="modal-title">New Tag</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Name</label>
                        <input name="TagName" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Note</label>
                        <input name="Note" class="form-control" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Create</button>
                </div>
            </form>
        </div>
    </div>
</div>

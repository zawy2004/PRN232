@using FUNewsManagement.Web.Models.Dtos
@model List<AccountDto>
@{
    ViewData["Title"] = "Accounts";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Accounts</h1>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createModal">+ New Account</button>
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Role</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var account in Model)
        {
            <tr>
                <td>@account.AccountName</td>
                <td>@account.AccountEmail</td>
                <td>@account.RoleName</td>
                <td class="text-end">
                    <button class="btn btn-sm btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#editModal-@account.AccountId">Edit</button>
                    <button class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#deleteModal-@account.AccountId">Delete</button>
                </td>
            </tr>

            <div class="modal fade" id="editModal-@account.AccountId" tabindex="-1">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <form asp-controller="Account" asp-action="Edit" asp-route-id="@account.AccountId" method="post">
                            <div class="modal-header">
                                <h5 class="modal-title">Edit Account</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body">
                                <div class="mb-3">
                                    <label class="form-label">Name</label>
                                    <input name="AccountName" value="@account.AccountName" class="form-control" required />
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Email</label>
                                    <input name="AccountEmail" type="email" value="@account.AccountEmail" class="form-control" required />
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Role</label>
                                    <select name="AccountRole" class="form-select">
                                        <option value="1" selected="@(account.AccountRole == 1)">Staff</option>
                                        <option value="2" selected="@(account.AccountRole == 2)">Lecturer</option>
                                    </select>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">New Password (leave blank to keep current)</label>
                                    <input name="Password" type="password" class="form-control" />
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                <button type="submit" class="btn btn-primary">Save</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <div class="modal fade" id="deleteModal-@account.AccountId" tabindex="-1">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <form asp-controller="Account" asp-action="Delete" asp-route-id="@account.AccountId" method="post">
                            <div class="modal-header">
                                <h5 class="modal-title">Delete Account</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body">
                                Delete account <strong>@account.AccountName</strong>? This cannot be undone.
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                <button type="submit" class="btn btn-danger">Delete</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        }
    </tbody>
</table>

<div class="modal fade" id="createModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-controller="Account" asp-action="Create" method="post">
                <div class="modal-header">
                    <h5 class="modal-title">New Account</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Name</label>
                        <input name="AccountName" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input name="AccountEmail" type="email" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Role</label>
                        <select name="AccountRole" class="form-select">
                            <option value="1">Staff</option>
                            <option value="2">Lecturer</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Password</label>
                        <input name="Password" type="password" class="form-control" required />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Create</button>
                </div>
            </form>
        </div>
    </div>
</div>

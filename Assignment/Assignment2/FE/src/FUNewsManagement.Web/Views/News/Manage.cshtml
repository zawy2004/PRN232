@using Microsoft.AspNetCore.Mvc.Rendering
@model FUNewsManagement.Web.Models.ViewModels.NewsManageViewModel
@{
    ViewData["Title"] = "Manage News";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Manage News</h1>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createModal">+ New Article</button>
</div>

<form method="get" asp-controller="News" asp-action="Manage" class="row g-2 mb-4">
    <div class="col-md-4">
        <input type="text" name="keyword" value="@Model.Keyword" class="form-control" placeholder="Search title, headline or tag..." />
    </div>
    <div class="col-md-3">
        <select name="tagId" class="form-select" asp-items="@(new SelectList(Model.AllTags, "TagId", "TagName", Model.TagId))">
            <option value="">-- Any tag --</option>
        </select>
    </div>
    <div class="col-md-3 form-check d-flex align-items-center">
        <input type="checkbox" name="mineOnly" value="true" class="form-check-input me-2" checked="@Model.MineOnly" id="mineOnlyCheck" />
        <label class="form-check-label" for="mineOnlyCheck">My articles only</label>
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-secondary w-100">Filter</button>
    </div>
</form>

<table class="table table-striped align-middle">
    <thead>
        <tr>
            <th>Headline</th>
            <th>Category</th>
            <th>Created</th>
            <th>By</th>
            <th>Status</th>
            <th>Tags</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var news in Model.News)
        {
            <tr>
                <td>@news.Headline</td>
                <td>@news.CategoryName</td>
                <td>@news.CreatedDate?.ToLocalTime().ToString("g")</td>
                <td>@news.CreatedByName</td>
                <td>
                    @* NewsStatus true = approved (visible to guests), false = pending *@
                    @if (news.NewsStatus)
                    {
                        <span class="badge bg-success">Approved</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">Pending</span>
                    }
                </td>
                <td>
                    @foreach (var tag in news.Tags)
                    {
                        <span class="badge bg-secondary me-1">@tag.TagName</span>
                    }
                </td>
                <td class="text-end text-nowrap">
                    @if (User.IsInRole("Admin") && !news.NewsStatus)
                    {
                        <form asp-controller="News" asp-action="Approve" asp-route-id="@news.NewsArticleId" method="post" class="d-inline">
                            <button type="submit" class="btn btn-sm btn-outline-success">Approve</button>
                        </form>
                    }
                    @if (news.CanEdit)
                    {
                        <button class="btn btn-sm btn-outline-secondary edit-news-btn" data-id="@news.NewsArticleId">Edit</button>
                    }
                    else
                    {
                        <button class="btn btn-sm btn-outline-secondary" disabled title="Approved articles can no longer be edited">Edit</button>
                    }
                    <button class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#deleteModal-@news.NewsArticleId">Delete</button>
                </td>
            </tr>

            <div class="modal fade" id="deleteModal-@news.NewsArticleId" tabindex="-1">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <form asp-controller="News" asp-action="Delete" asp-route-id="@news.NewsArticleId" method="post">
                            <div class="modal-header">
                                <h5 class="modal-title">Delete Article</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body">
                                Delete article <strong>@news.Headline</strong>? This cannot be undone.
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                <button type="submit" class="btn btn-danger">Delete</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        }
    </tbody>
</table>

@{
    var tagCheckboxes = Model.AllTags;
    var categoryOptions = Model.Categories;
}

<!-- Create modal -->
<div class="modal fade" id="createModal" tabindex="-1">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <form asp-controller="News" asp-action="Create" method="post">
                <div class="modal-header">
                    <h5 class="modal-title">New Article</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <partial name="_NewsFormFields" model="@(("create", categoryOptions, tagCheckboxes))" />
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Create</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit modal (shared; populated via fetch when an Edit button is clicked) -->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <form id="editForm" asp-controller="News" asp-action="Edit" method="post">
                <div class="modal-header">
                    <h5 class="modal-title">Edit Article</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <partial name="_NewsFormFields" model="@(("edit", categoryOptions, tagCheckboxes))" />
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.ckeditor.com/ckeditor5/41.4.2/classic/ckeditor.js"></script>
    <script>
        let createEditor, editEditor;
        ClassicEditor.create(document.querySelector('#create-NewsContent')).then(editor => createEditor = editor);
        ClassicEditor.create(document.querySelector('#edit-NewsContent')).then(editor => editEditor = editor);

        document.querySelectorAll('.edit-news-btn').forEach(function (btn) {
            btn.addEventListener('click', async function () {
                const id = btn.getAttribute('data-id');
                const response = await fetch('/News/GetJson/' + encodeURIComponent(id));
                if (!response.ok) { alert('Could not load article.'); return; }
                const news = await response.json();

                document.getElementById('editForm').action = '/News/Edit/' + encodeURIComponent(id);
                document.getElementById('edit-NewsTitle').value = news.newsTitle || '';
                document.getElementById('edit-Headline').value = news.headline || '';
                document.getElementById('edit-NewsSource').value = news.newsSource || '';
                document.getElementById('edit-CategoryId').value = news.categoryId || '';
                document.getElementById('edit-NewTagNamesInput').value = '';

                document.querySelectorAll('#edit-tags input[type=checkbox]').forEach(function (cb) {
                    cb.checked = news.tags.some(t => t.tagId.toString() === cb.value);
                });

                if (editEditor) editEditor.setData(news.newsContent || '');

                new bootstrap.Modal(document.getElementById('editModal')).show();
            });
        });
    </script>
}

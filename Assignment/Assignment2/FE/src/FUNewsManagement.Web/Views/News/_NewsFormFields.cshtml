@using FUNewsManagement.Web.Models.Dtos
@model (string Prefix, List<CategoryTreeDto> Categories, List<TagDto> Tags)
@{
    var p = Model.Prefix;

    // Đọc đúng cấu trúc cha-con của bảng Category (qua CategoryTreeDto) và "duỗi" cây ra thành 1
    // list phẳng có kèm độ sâu (depth), để <select> vẫn là 1 danh sách <option> thường nhưng hiển
    // thị thụt lề theo cấp - phản ánh đúng dữ liệu DB (Academic news > Technology > .NET/Java...).
    var flatCategories = new List<(CategoryTreeDto Category, int Depth)>();
    void FlattenCategoryTree(IEnumerable<CategoryTreeDto> nodes, int depth)
    {
        foreach (var node in nodes)
        {
            flatCategories.Add((node, depth));
            FlattenCategoryTree(node.Children, depth + 1);
        }
    }
    FlattenCategoryTree(Model.Categories, 0);
}

<div class="mb-3">
    <label class="form-label">Title</label>
    <input id="@(p)-NewsTitle" name="NewsTitle" class="form-control" />
</div>
<div class="mb-3">
    <label class="form-label">Headline</label>
    <input id="@(p)-Headline" name="Headline" class="form-control" required />
</div>
<div class="row">
    <div class="col-md-6 mb-3">
        <label class="form-label">Category</label>
        <select id="@(p)-CategoryId" name="CategoryId" class="form-select">
            <option value="">-- Select category --</option>
            @foreach (var (category, depth) in flatCategories)
            {
                var indent = new string(' ', depth * 4);
                <option value="@category.CategoryId">@(indent)@(depth > 0 ? "↳ " : "")@category.CategoryName</option>
            }
        </select>
    </div>
    <div class="col-md-6 mb-3">
        <label class="form-label">Source</label>
        <input id="@(p)-NewsSource" name="NewsSource" class="form-control" />
    </div>
</div>
<div class="mb-3">
    <label class="form-label">Content</label>
    <textarea id="@(p)-NewsContent" name="NewsContent" rows="8"></textarea>
</div>
<div class="alert alert-info py-2 small mb-3">
    Bài viết mới sẽ ở trạng thái <strong>Chờ duyệt</strong> và chỉ hiển thị cho mọi người sau khi Admin phê duyệt.
</div>
<div class="mb-3" id="@(p)-tags">
    <label class="form-label">Tags</label>
    <div>
        @foreach (var tag in Model.Tags)
        {
            <div class="form-check form-check-inline">
                <input type="checkbox" class="form-check-input" name="TagIds" value="@tag.TagId" id="@(p)-tag-@tag.TagId" />
                <label class="form-check-label" for="@(p)-tag-@tag.TagId">@tag.TagName</label>
            </div>
        }
    </div>
</div>
<div class="mb-3">
    <label class="form-label">New tags (comma-separated, optional)</label>
    <input id="@(p)-NewTagNamesInput" name="newTagNamesInput" class="form-control" placeholder="e.g. AI, Robotics" />
</div>
